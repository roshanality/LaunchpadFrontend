<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # SPA fallback for React Router: if the request is not a real file/folder,
  # serve index.html so routes like /login work on refresh and direct open.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api
  RewriteRule . /index.html [L]
</IfModule>
